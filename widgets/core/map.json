{
  "type": "core.map",
  "version": "0.1.0",
  "title": "地图",
  "description": "Scene / world map with locations.",
  "stateSchema": {
    "type": "object",
    "properties": {
      "current": { "type": "string", "description": "Current location id." },
      "locations": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "name"],
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "x": { "type": "number" },
            "y": { "type": "number" },
            "visited": { "type": "boolean" }
          }
        }
      }
    }
  },
  "intents": ["map.travel"],
  "capabilities": ["read:state"],
  "entry": { "kind": "builtin" },
  "author": "AIRP",
  "license": "MIT OR Apache-2.0"
}
