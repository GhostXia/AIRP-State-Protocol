{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AIRP UI",
  "version": "0.1.0",
  "identifier": "com.airp.ui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      { "title": "AIRP UI", "width": 1200, "height": 800 }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": false
  }
}
